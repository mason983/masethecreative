# Keep this file as a template. Never commit a real API key.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.6-luna
# Public browser configuration. The publishable/anon key is safe to expose only
# because every portal table and storage object is protected by RLS.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only secret. Never expose this value in build output or browser code.
SUPABASE_SERVICE_ROLE_KEY=
# Used in Supabase invitation and password-reset redirects.
SITE_URL=http://localhost:4173
PORT=4173
